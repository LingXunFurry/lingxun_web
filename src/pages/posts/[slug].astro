---
// src/pages/posts/[slug].astro
// 【核心修改 1】：从 astro:content 中额外引入最新版的 render 渲染引擎
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 获取所有 posts 集合里的文章，并生成路由
export async function getStaticPaths() {
    const postEntries = await getCollection('posts');
    return postEntries.map(entry => ({
        // 【核心修改 2】：把 entry.slug 换成 entry.id！用新版的标识符去填 slug 的坑
        params: { slug: entry.id }, 
        props: { entry },
    }));
}

// 获取当前被点击的文章数据
const { entry } = Astro.props;
// 【核心修改 3】：废弃旧版的 entry.render()，使用全新的 render(entry) 函数解析正文
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | 龙宫档案`}>
    
    <main style="padding-top: 140px;" class="relative min-h-screen bg-[#050b14] overflow-x-hidden z-0 pb-32">
        
        <div class="absolute inset-0 bg-[radial-gradient(rgba(148,163,184,0.08)_1px,transparent_1px)] bg-[size:3rem_3rem] pointer-events-none z-0"></div>
        <div class="absolute top-[10%] left-1/2 -translate-x-1/2 w-[60vw] h-[600px] bg-blue-600/[0.04] rounded-full blur-[150px] pointer-events-none z-0"></div>

        <div class="container mx-auto px-6 max-w-3xl relative z-10 flex flex-col">
            
            <a href="/posts" class="group flex items-center gap-2 text-slate-500 hover:text-amber-400 transition-colors font-mono tracking-widest text-xs mb-12 w-fit">
                <span class="transform group-hover:-translate-x-1 transition-transform">&lt;</span>
                RETURN_TO_ARCHIVE_LIST
            </a>

            <header class="mb-12 pb-10 border-b border-slate-800 relative">
                <div class="flex items-center gap-4 mb-6">
                    <span class="text-sm font-mono text-slate-500 tracking-widest">{entry.data.date}</span>
                    <span class="text-[10px] font-mono tracking-widest uppercase text-amber-500/70 border border-amber-500/30 bg-amber-500/10 px-2 py-0.5">
                        // {entry.data.tag}
                    </span>
                </div>
                
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-wide leading-tight mb-6">
                    {entry.data.title}
                </h1>
                
                <p class="text-slate-400 font-light leading-relaxed text-sm md:text-base border-l-2 border-slate-700 pl-4">
                    {entry.data.desc}
                </p>

                <div class="absolute bottom-0 left-0 w-1/3 h-[1px] bg-gradient-to-r from-amber-500 to-transparent opacity-50"></div>
            </header>

            <article class="markdown-body">
                <Content />
            </article>

        </div>
    </main>
</Layout>

<style is:global>
    .markdown-body {
        color: #94a3b8; 
        font-size: 1.05rem;
        line-height: 1.8;
        font-weight: 300;
    }

    .markdown-body h1, 
    .markdown-body h2, 
    .markdown-body h3 {
        color: #f8fafc; 
        font-weight: 700;
        margin-top: 2.5em;
        margin-bottom: 1em;
        letter-spacing: 0.025em;
    }

    .markdown-body h2 {
        font-size: 1.5rem;
        border-bottom: 1px solid rgba(30, 41, 59, 0.8); 
        padding-bottom: 0.5em;
        display: inline-block;
        padding-right: 1em;
    }

    .markdown-body p {
        margin-bottom: 1.5em;
        text-align: justify;
    }

    .markdown-body strong {
        color: #fcd34d; 
        font-weight: 600;
    }

    .markdown-body blockquote {
        border-left: 3px solid #fbbf24; 
        background: rgba(251, 191, 36, 0.05);
        margin: 2em 0;
        padding: 1em 1.5em;
        color: #cbd5e1; 
        font-style: italic;
        border-radius: 0 0.5rem 0.5rem 0;
    }

    .markdown-body code {
        font-family: monospace;
        background: rgba(30, 41, 59, 0.8);
        color: #fbbf24;
        padding: 0.2em 0.4em;
        border-radius: 0.25rem;
        font-size: 0.85em;
    }
</style>