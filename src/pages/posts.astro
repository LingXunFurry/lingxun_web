---
// src/pages/posts.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 获取全量动态，并按时间降序排列
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
    return new Date(b.data.date.replace(/\./g, '-')).valueOf() - new Date(a.data.date.replace(/\./g, '-')).valueOf();
});
---

<Layout title="动态日志 | 凌巽的龙宫">
    
    <main style="padding-top: 160px;" class="relative min-h-screen bg-[#050b14] overflow-x-hidden z-0 pb-32 flex flex-col">
        
        <div class="absolute inset-0 bg-[radial-gradient(rgba(148,163,184,0.1)_1px,transparent_1px)] bg-[size:3rem_3rem] pointer-events-none z-0"></div>
        <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[130px] pointer-events-none z-0 animate-breath-slow"></div>
        <div class="absolute bottom-[10%] right-[-10%] w-[500px] h-[500px] bg-amber-500/[0.06] rounded-full blur-[120px] pointer-events-none z-0 animate-breath-slower"></div>
        
        <div class="container mx-auto px-6 max-w-4xl relative z-10 flex-grow flex flex-col gap-16">
            
            <div class="text-center flex flex-col items-center">
                <div class="flex items-center gap-4 mb-4">
                    <span class="w-8 h-[2px] bg-amber-500"></span>
                    <span class="text-slate-400 font-mono text-xs tracking-widest uppercase bg-slate-900 px-3 py-1 border border-slate-800 shadow-[0_0_15px_rgba(251,191,36,0.15)]">Data Stream</span>
                    <span class="w-8 h-[2px] bg-amber-500"></span>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold text-white tracking-wider mb-6">
                    最新 <span class="text-slate-500 font-light">动态</span>
                </h1>
                <p class="text-slate-400 font-light max-w-xl text-xs md:text-sm leading-relaxed tracking-wide">
                    此处的频率与现实同步。记录程序更迭、生活切片与灵感掉落。所有未公开的归档都在这里无尽流淌。
                </p>
            </div>

            <div class="flex flex-col gap-6 w-full">
                {sortedPosts.map((post) => (
                    // 同样使用 <a> 标签并指向自动生成的路由
                    <a href={`/posts/${post.id}`} class="group relative block w-full p-6 bg-[#091121]/60 backdrop-blur-md border border-slate-800 rounded-xl transition-all duration-300 hover:border-slate-700 hover:bg-[#0c182e]/80 shadow-lg">
                        
                        <div class="absolute top-0 left-6 w-8 h-[2px] bg-amber-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4 pb-3 border-b border-slate-800/60">
                            <div class="flex items-center gap-4">
                                <span class="text-xs font-mono text-slate-500 tracking-widest">
                                    {post.data.date}
                                </span>
                                <span class="text-[10px] font-mono tracking-widest uppercase px-2 py-0.5 border rounded text-amber-500 border-amber-500/30 bg-amber-500/5">
                                    // {post.data.tag}
                                </span>
                            </div>
                            <span class="text-[10px] font-mono text-slate-600 hidden md:inline-block select-none">
                                LOG_INDEX // #{post.id.toUpperCase().substring(0, 4)}
                            </span>
                        </div>

                        <h2 class="text-xl font-bold text-white mb-2 group-hover:text-amber-300 transition-colors duration-300">
                            {post.data.title}
                        </h2>
                        <p class="text-sm text-slate-400 font-light leading-relaxed tracking-wide text-justify group-hover:text-slate-300 transition-colors line-clamp-2">
                            {post.data.desc}
                        </p>
                    </a>
                ))}
            </div>

            <div class="mt-8 flex justify-center">
                <a href="/#" class="group flex items-center gap-2 text-slate-500 hover:text-amber-400 transition-colors font-mono tracking-widest text-xs">
                    <span class="transform rotate-180 inline-block group-hover:-translate-x-1 transition-transform">&gt;</span>
                    RETURN_TO_MAIN_TERMINAL
                </a>
            </div>

        </div>
    </main>
</Layout>

<style>
    @keyframes breath-blue {
        0%, 100% { transform: scale(1) translate(0px, 0px); opacity: 0.8; }
        50% { transform: scale(1.15) translate(20px, 15px); opacity: 1; }
    }
    @keyframes breath-amber {
        0%, 100% { transform: scale(1.1) translate(0px, 0px); opacity: 0.9; }
        50% { transform: scale(0.95) translate(-15px, -10px); opacity: 0.7; }
    }
    .animate-breath-slow {
        animation: breath-blue 9s ease-in-out infinite;
        will-change: transform, opacity;
    }
    .animate-breath-slower {
        animation: breath-amber 14s ease-in-out infinite;
        will-change: transform, opacity;
    }
</style>