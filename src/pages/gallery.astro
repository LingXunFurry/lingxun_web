---
// src/pages/gallery.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'; 

// =================================================================
// 1. 【全自动引擎】：读取所有本地相册资产
// =================================================================
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/*.{jpeg,jpg,png,PNG,webp}');
const imagePaths = Object.values(images);

const galleryImages = await Promise.all(imagePaths.map(async (img) => {
    const data = await img();
    return data.default;
}));

// =================================================================
// 2. 【自动发牌器 v2.0】：带高度保底的循环洗牌算法
// =================================================================
const col1 = [];
const col2 = [];
const col3 = [];
const col4 = [];

const minItemsPerColumn = 5;
const totalNeeded = Math.max(galleryImages.length, minItemsPerColumn * 4);

for (let i = 0; i < totalNeeded; i++) {
    const img = galleryImages[i % galleryImages.length]; 
    if (i % 4 === 0) col1.push(img);
    else if (i % 4 === 1) col2.push(img);
    else if (i % 4 === 2) col3.push(img);
    else col4.push(img);
}
// =================================================================
---

<Layout title="视觉画廊 | 凌巽的龙宫">
    
    <main style="padding-top: 140px;" class="relative min-h-screen bg-[#050b14] overflow-hidden z-0 flex flex-col pb-12">
        
        {/* ========================================================= */}
        {/* 【画廊专用 - 光学镜头 (Cinematic Lens)】电影级纯享背景 */}
        {/* ========================================================= */}
        {/* 修复：使用 100dvh 锁定动态视口，彻底解决手机端高度乱跑问题 */}
        <div class="fixed top-0 left-0 w-full h-[100dvh] z-0 pointer-events-none overflow-hidden bg-[#050505]">
            
            {/* 1. 光漏效果 (Light Leaks) - 修复：改用固定的超大 px 像素值，确保在手机端绝对可见且不会缩水 */}
            <div class="absolute top-[-10%] left-[-20%] w-[600px] h-[600px] md:w-[1000px] md:h-[1000px] bg-red-700/10 rounded-full blur-[100px] mix-blend-screen animate-lens-drift"></div>
            <div class="absolute bottom-[-10%] right-[-20%] w-[500px] h-[500px] md:w-[900px] md:h-[900px] bg-cyan-700/10 rounded-full blur-[100px] mix-blend-screen animate-lens-drift-reverse"></div>

            {/* 2. 电影胶片噪点 (Film Grain) */}
            <div class="absolute inset-0 opacity-[0.08] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

            {/* 3. 极致暗角 (Heavy Vignette) - 聚拢视觉中心 */}
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#000000_120%)]"></div>
        </div>
        {/* ========================================================= */}

        {/* ========================================================= */}
        {/* 【单反级 HUD 取景框】 - 纯净自检版：全角顺时针显影，移除中央遮挡 */}
        {/* ========================================================= */}
        <div class="fixed inset-0 z-20 pointer-events-none pt-24 pb-6 px-4 md:pt-32 md:pb-10 md:px-10">
            <div class="relative w-full h-full">

                {/* --- 1. 左上角：系统挂载 (延迟 0.2s 开始) --- */}
                <div class="absolute top-0 left-0 w-8 h-8 md:w-16 md:h-16 border-t-[1.5px] border-l-[1.5px] border-slate-300/50"></div>
                <div class="absolute top-3 left-4 md:top-6 md:left-6 font-mono text-[10px] md:text-xs text-slate-300 tracking-widest flex flex-col gap-1 drop-shadow-md">
                    <span class="text-red-500 flex items-center gap-1.5 mb-1 animate-hud-reveal" style="animation-delay: 0.2s;">
                        <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span> REC
                    </span>
                    <span class="animate-hud-reveal" style="animation-delay: 0.3s;">35MM LENS</span>
                    <span class="animate-hud-reveal" style="animation-delay: 0.4s;">F/1.4</span>
                </div>

                {/* --- 2. 右上角：环境参数测定 (延迟 0.6s 开始) --- */}
                <div class="absolute top-0 right-0 w-8 h-8 md:w-16 md:h-16 border-t-[1.5px] border-r-[1.5px] border-slate-300/50"></div>
                <div class="absolute top-3 right-4 md:top-6 md:right-6 font-mono text-[10px] md:text-xs text-slate-300 tracking-widest text-right flex flex-col gap-1 drop-shadow-md">
                    <span class="flex items-center justify-end gap-1.5 mb-1 animate-hud-reveal" style="animation-delay: 0.6s;">
                        BAT <div class="w-4 h-2 md:w-5 md:h-2.5 border border-slate-300/80 p-[1px]"><div class="w-[80%] h-full bg-slate-300/80"></div></div>
                    </span>
                    <span class="animate-hud-reveal" style="animation-delay: 0.7s;">ISO_100</span>
                    <span class="animate-hud-reveal" style="animation-delay: 0.8s;">EXP +0.3</span>
                </div>

                {/* --- 3. 左下角：档案读取 (延迟 1.0s 开始) --- */}
                <div class="absolute bottom-0 left-0 w-8 h-8 md:w-16 md:h-16 border-b-[1.5px] border-l-[1.5px] border-slate-300/50"></div>
                <div class="absolute bottom-3 left-4 md:bottom-6 md:left-6 font-mono text-[10px] md:text-xs text-slate-300 tracking-widest flex flex-col gap-1 drop-shadow-md">
                    <span class="animate-hud-reveal" style="animation-delay: 1.0s;">RAW+JPEG</span>
                    <span class="text-slate-400 animate-hud-reveal" style="animation-delay: 1.1s;">ARCHIVE_NO.042</span>
                </div>

                {/* --- 4. 右下角：焦点锁定确认 (延迟 1.3s 开始) --- */}
                <div class="absolute bottom-0 right-0 w-8 h-8 md:w-16 md:h-16 border-b-[1.5px] border-r-[1.5px] border-slate-300/50"></div>
                <div class="absolute bottom-3 right-4 md:bottom-6 md:right-6 font-mono text-[10px] md:text-xs text-slate-300 tracking-widest text-right flex flex-col gap-1 drop-shadow-md">
                    <span class="animate-hud-reveal" style="animation-delay: 1.3s;">AF-S / WIDE</span>
                    <span class="text-emerald-400/90 font-bold animate-hud-reveal" style="animation-delay: 1.4s;">FOCUS LOCKED</span>
                </div>

                {/* 中央的辅助线和十字对焦框已彻底粉碎，把视觉中心 100% 还给照片 */}

            </div>
        </div>
        {/* ========================================================= */}

        <div class="container mx-auto px-6 max-w-7xl relative z-10 flex flex-col h-full">
            <div class="mb-10 text-center flex flex-col items-center flex-shrink-0">
                <div class="flex items-center gap-4 mb-4">
                    <span class="w-8 h-[2px] bg-amber-500"></span>
                    <span class="text-slate-400 font-mono text-xs tracking-widest uppercase bg-slate-900 px-3 py-1 border border-slate-800 shadow-[0_0_15px_rgba(251,191,36,0.15)]">Visual Archive</span>
                    <span class="w-8 h-[2px] bg-amber-500"></span>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold text-white tracking-wider mb-6 drop-shadow-lg">
                    视觉 <span class="text-slate-500 font-light">画廊</span>
                </h1>
                <p class="text-slate-400 font-light max-w-xl text-xs md:text-sm leading-relaxed tracking-wide">
                    在这里，时间被切片，记忆被定格为像素。所有的旅途碎片，都在这条数据传送带上无尽循环。
                </p>
            </div>

            <div class="w-full h-[55vh] lg:h-[65vh] relative overflow-hidden [mask-image:linear-gradient(to_bottom,black_90%,transparent_100%)]">
                <div class="absolute inset-0 grid grid-cols-2 lg:grid-cols-4 gap-6 px-2">
                    <div class="group h-full relative overflow-hidden">
                        <div class="animate-conveyor flex flex-col gap-6" style="animation-duration: 25s;">
                            {col1.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                            {col1.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_Clone_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                        </div>
                    </div>
                    <div class="group h-full relative overflow-hidden">
                        <div class="animate-conveyor flex flex-col gap-6" style="animation-duration: 35s; transform: translateY(-15%);">
                            {col2.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                            {col2.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_Clone_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                        </div>
                    </div>
                    <div class="group h-full relative overflow-hidden hidden lg:block">
                        <div class="animate-conveyor flex flex-col gap-6" style="animation-duration: 40s;">
                            {col3.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                            {col3.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_Clone_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                        </div>
                    </div>
                    <div class="group h-full relative overflow-hidden hidden lg:block">
                        <div class="animate-conveyor flex flex-col gap-6" style="animation-duration: 22s; transform: translateY(-10%);">
                            {col4.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                            {col4.map((img, index) => (<div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video"><Image src={img} alt={`Archive_Clone_${index}`} class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" /></div>))}
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-8 flex justify-center z-20">
                <a href="/#" class="group flex items-center gap-2 text-slate-500 hover:text-amber-400 transition-colors font-mono tracking-widest text-xs">
                    <span class="transform rotate-180 inline-block group-hover:-translate-x-1 transition-transform">&gt;</span>
                    RETURN_TO_MAIN_TERMINAL
                </a>
            </div>
        </div>
    </main>

    <div id="lightbox-modal" class="fixed inset-0 bg-black/95 backdrop-blur-xl z-50 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500">
        
        <canvas id="lightbox-particles" class="absolute inset-0 w-full h-full z-0 pointer-events-none opacity-60"></canvas>

        <div class="absolute top-6 right-6 flex items-center gap-4 z-50">
            <button id="modal-download" class="group flex items-center gap-2 text-amber-400/80 hover:text-amber-400 font-mono text-sm transition-all px-4 py-2 bg-slate-900/50 rounded-lg border border-amber-500/30 hover:border-amber-400 shadow-[0_0_10px_rgba(251,191,36,0)] hover:shadow-[0_0_15px_rgba(251,191,36,0.3)]">
                <svg class="w-4 h-4 transform group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                // SAVE
            </button>
            <button id="modal-close" class="text-slate-400 hover:text-white font-mono text-sm transition-colors px-4 py-2 bg-slate-900/50 rounded-lg border border-slate-800">
                // CLOSE ×
            </button>
        </div>

        <div class="relative z-10 max-w-[90vw] max-h-[85vh] rounded-xl border border-amber-500/30 bg-slate-950 animate-breath-glow">
            <img id="modal-img" src="" alt="Enlarged Archive" class="w-full h-full object-contain max-h-[85vh] rounded-xl transform scale-95 transition-transform duration-500 ease-out" />
        </div>

    </div>
</Layout>

<script>
    import { escapeHtml, fetchPublic, toApiUrl, type GalleryPhoto } from '../lib/publicContent';

    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('lightbox-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeBtn = document.getElementById('modal-close');
        const downloadBtn = document.getElementById('modal-download');
        appendBackendGalleryColumns();
        
        // -------------------------------------------------------------
        // 按需渲染粒子系统
        // -------------------------------------------------------------
        const canvas = document.getElementById('lightbox-particles') as HTMLCanvasElement;
        const ctx = canvas?.getContext('2d');
        let particleAnimationId: number;
        let particles: Array<{x: number, y: number, size: number, speedY: number, alpha: number}> = [];

        function initParticles() {
            if (!ctx) return;
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            particles = [];
            for (let i = 0; i < 80; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 2 + 0.5,
                    speedY: Math.random() * 0.5 + 0.1,
                    alpha: Math.random() * 0.5 + 0.1
                });
            }
        }

        function animateParticles() {
            if (!ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            particles.forEach(p => {
                p.y -= p.speedY; // 粒子向上漂浮
                
                // 绘制发光粒子
                ctx.fillStyle = `rgba(251, 191, 36, ${p.alpha})`; // 琥珀色
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();

                // 越界重置到屏幕底部
                if (p.y < 0) {
                    p.y = canvas.height;
                    p.x = Math.random() * canvas.width;
                }
            });
            particleAnimationId = requestAnimationFrame(animateParticles);
        }

        if (modal && modalImg) {
            // 打开模态框
            document.addEventListener('click', (e) => {
                    const target = (e.target as HTMLElement).closest('.gallery-trigger') as HTMLImageElement | null;
                    if (!target) return;
                    modalImg.src = target.src;
                    
                    // 解除隐藏
                    modal.classList.remove('opacity-0', 'pointer-events-none');
                    setTimeout(() => {
                        modalImg.classList.remove('scale-95');
                        modalImg.classList.add('scale-100');
                    }, 50);

                    // 点火：启动粒子系统
                    initParticles();
                    animateParticles();
            });

            // =========================================================
            // 终极下载逻辑：通过 Blob 拦截，重命名并修正格式
            // =========================================================
            downloadBtn?.addEventListener('click', async () => {
                if (!modalImg.src) return;
                
                // 1. 改变按钮状态，营造科技感
                const originalContent = downloadBtn.innerHTML;
                downloadBtn.innerHTML = '<span class="animate-pulse">// DOWNLOADING...</span>';
                
                try {
                    // 2. 将图片作为纯二进制数据 (Blob) 抓取到浏览器内存中
                    const response = await fetch(modalImg.src);
                    const blob = await response.blob();
                    
                    // 3. 智能解析并清理文件名
                    let fileName = 'lingxun_archive.webp'; // 默认保底名
                    
                    try {
                        const urlObj = new URL(modalImg.src, window.location.origin);
                        // 尝试剥离 Astro dev 模式下的复杂参数，提取原文件名
                        const hrefParam = urlObj.searchParams.get('href'); 
                        if (hrefParam) {
                            fileName = hrefParam.split('/').pop()?.split('?')[0] || fileName;
                        } else {
                            // build 生产模式下的处理
                            fileName = modalImg.src.split('/').pop()?.split('?')[0] || fileName; 
                        }
                    } catch (e) {
                        // 如果解析失败，直接使用保底名
                    }

                    // 4. 强制后缀修正：因为 Astro 已经将其优化成了 webp 格式
                    if (!fileName.toLowerCase().endsWith('.webp')) {
                        fileName = fileName.replace(/\.[^/.]+$/, "") + ".webp";
                    }

                    // 5. 创建纯净的本地下载链接
                    const blobUrl = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = blobUrl;
                    a.download = fileName;
                    
                    document.body.appendChild(a);
                    a.click();
                    
                    // 6. 过河拆桥，清理内存防泄漏
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(blobUrl);
                    
                } catch (error) {
                    console.error("下载出错:", error);
                    alert("档案提取失败，请重试");
                } finally {
                    // 恢复按钮原始状态
                    downloadBtn.innerHTML = originalContent;
                }
            });
            // =========================================================

            // 关闭模态框函数
            const closeModal = () => {
                modalImg.classList.remove('scale-100');
                modalImg.classList.add('scale-95');
                modal.classList.add('opacity-0', 'pointer-events-none');
                
                // 熄火：停止粒子计算，释放 CPU
                cancelAnimationFrame(particleAnimationId);
                
                setTimeout(() => { modalImg.src = ""; }, 500);
            };

            closeBtn?.addEventListener('click', closeModal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal || e.target === canvas) closeModal();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });
        }
    });

    async function appendBackendGalleryColumns() {
        const photos = await fetchPublic<GalleryPhoto[]>('/api/public/gallery');
        if (!photos?.length) return;

        const columns = Array.from(document.querySelectorAll('.animate-conveyor')) as HTMLElement[];
        if (!columns.length) return;

        columns.forEach((column) => {
            column.innerHTML = '';
        });

        const totalNeeded = Math.max(photos.length, 20);
        for (let index = 0; index < totalNeeded; index++) {
            const photo = photos[index % photos.length];
            const column = columns[index % columns.length];
            const item = renderBackendPhoto(photo, index);
            column.insertAdjacentHTML('beforeend', item);
        }

        columns.forEach((column) => {
            column.insertAdjacentHTML('beforeend', column.innerHTML);
        });
    }

    function renderBackendPhoto(photo: GalleryPhoto, index: number) {
        const alt = escapeHtml(photo.title || photo.original_filename || `Backend_Archive_${index + 1}`);
        return `
            <div class="relative rounded-lg overflow-hidden border border-slate-800/80 bg-slate-900 cursor-pointer hover:z-50 aspect-video">
                <img src="${toApiUrl(photo.file_url)}" alt="${alt}" class="gallery-trigger w-full h-full object-cover opacity-80 hover:opacity-100 transition-opacity duration-300" loading="lazy" decoding="async" />
            </div>
        `;
    }
</script>

<style>
    /* -------------------------------------------------------------
       新增：HUD 文本终端启动动画 (Staggered Reveal)
       ------------------------------------------------------------- */
    @keyframes hudReveal {
        0% { 
            opacity: 0; 
            transform: translateY(8px); /* 初始状态藏在下方 8px 处 */
        }
        100% { 
            opacity: 0.9; 
            transform: translateY(0); /* 归位 */
        }
    }
    .animate-hud-reveal {
        opacity: 0; /* 强制初始不可见，等待 delay 结束 */
        /* 使用 cubic-bezier(0.16, 1, 0.3, 1) 实现非常干脆的“机械回弹”减速效果 */
        animation: hudReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        will-change: transform, opacity;
    }

    /* -------------------------------------------------------------
       新增：光学漏光缓慢漂移效果
       ------------------------------------------------------------- */
    @keyframes lensDrift {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(3vw, -2vh) scale(1.05); }
        100% { transform: translate(0, 0) scale(1); }
    }
    .animate-lens-drift {
        animation: lensDrift 15s ease-in-out infinite alternate;
        will-change: transform;
    }
    .animate-lens-drift-reverse {
        animation: lensDrift 18s ease-in-out infinite alternate-reverse;
        will-change: transform;
    }

    /* -------------------------------------------------------------
       原有动画保持不变
       ------------------------------------------------------------- */
    /* 传送带动画 */
    @keyframes conveyor {
        0% { transform: translateY(0); }
        100% { transform: translateY(calc(-50% - 12px)); } 
    }
    .animate-conveyor {
        animation: conveyor linear infinite;
        will-change: transform;
    }
    .group:hover .animate-conveyor {
        animation-play-state: paused;
    }

    /* 呼吸辉光动画 */
    @keyframes breathGlow {
        0% { box-shadow: 0 0 30px rgba(251, 191, 36, 0.15); }
        50% { box-shadow: 0 0 80px rgba(251, 191, 36, 0.4); }
        100% { box-shadow: 0 0 30px rgba(251, 191, 36, 0.15); }
    }
    .animate-breath-glow {
        animation: breathGlow 4s ease-in-out infinite;
    }
</style>
