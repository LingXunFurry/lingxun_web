---
// Hero.astro 首屏组件
import { Image } from 'astro:assets';

// =================================================================
// 1. 全自动读取画廊文件夹
// =================================================================
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/*.{jpeg,jpg,png,PNG,webp}');
const imagePaths = Object.values(images);

const allGalleryImages = await Promise.all(imagePaths.map(async (img) => {
    const data = await img();
    return data.default;
}));

// =================================================================
// 2. 性能截断：只取画廊文件夹里的前 4 张图作为首屏轮播，防止 DOM 过载
// =================================================================
const heroImages = allGalleryImages.slice(0, 4);
---

<section class="snap-start relative w-full h-screen overflow-hidden">

    <div id="bg-carousel" class="absolute inset-0 w-full h-full z-0 bg-slate-950">
        {/* 利用遍历动态生成图片标签：
            如果是第一张图 (index === 0)，默认显示 (opacity-100)
            如果是其他图，默认隐藏 (opacity-0)，等待 JS 轮播接管
        */}
        {heroImages.map((img, index) => (
            <Image
                src={img}
                alt={`龙宫档案首屏_${index + 1}`}
                width={1920}
                format="webp"
                quality={index === 0 ? 78 : 70}
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : "low"}
                class={`carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
            />
        ))}
    </div>

    <div class="absolute inset-0 w-full h-full bg-slate-950/65 z-10"></div>

    <canvas id="particle-canvas" class="absolute top-0 left-0 w-full h-full z-20"></canvas>

    {/* ================================================================= */}
    {/* 文字区域：注入动能显影动画类 (animate-hero-xxx) */}
    {/* ================================================================= */}
    <div class="absolute bottom-32 left-8 md:left-24 z-30 text-left pointer-events-none">
        {/* 标题 */}
        <h1 class="text-5xl md:text-7xl font-bold text-white tracking-wider mb-4 drop-shadow-lg opacity-0 animate-hero-title">
            凌巽的<span class="text-amber-400">龙窝</span>
        </h1>
        {/* 副标题 */}
        <p class="text-lg md:text-xl text-slate-300 tracking-wide font-light opacity-0 animate-hero-subtitle">
            向下滚动,探索更多
        </p>
    </div>

    {/* 向下指引箭头：为了防止 transform 冲突，多包裹一层 div 来施加出场动画 */}
    <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 z-30 text-white/70 pointer-events-none">
        <div class="opacity-0 animate-hero-arrow">
            <svg class="w-8 h-8 md:w-10 md:h-10 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
        </div>
    </div>
</section>

<script>
    // 动画核心逻辑
    document.addEventListener('DOMContentLoaded', () => {
        // 背景轮播图算法
        const images = document.querySelectorAll('.carousel-img');
        let currentIndex = 0;

        if (images.length > 0) {
            // 每5秒执行一次切换
            setInterval(() => {
                // 把当前显示的图片透明度设为 0
                images[currentIndex].classList.remove('opacity-100');
                images[currentIndex].classList.add('opacity-0');

                // 计算下一张图片的索引（取余保证最后一张之后是第一张，形成循环）
                currentIndex = (currentIndex + 1) % images.length;

                // 把下一张图片的透明度设为 1
                images[currentIndex].classList.remove('opacity-0');
                images[currentIndex].classList.add('opacity-100');
            }, 5000);
        }

        // 粒子流动算法
        const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d');
        if(!ctx) return;

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isMobile = window.matchMedia('(max-width: 768px)').matches;
        const lowCoreDevice = (navigator.hardwareConcurrency || 8) <= 4;
        if (reducedMotion) {
            canvas.remove();
            return;
        }

        // 画布尺寸适应浏览器窗口尺寸
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        // 记录鼠标位置,初始情况在屏幕外
        let mouse = { x: -1000, y: -1000 };

        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });

        window.addEventListener('mouseout', () => {
            mouse.x = -1000;
            mouse.y = -1000;
        });

        // 升级版：流体粒子类
        class Particle {
            x: number;
            y: number;
            size: number;
            vx: number; // 水平流速
            vy: number; // 垂直流速

            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.size = (Math.random() * 2) + 1;
                // 赋予每个粒子随机的流动速度 (-0.5 到 0.5 之间)
                this.vx = (Math.random() - 0.5) * 1;
                this.vy = (Math.random() - 0.5) * 1;
            }

            // 计算下一帧状态
            update() {
                // 按照流速自然移动
                this.x += this.vx;
                this.y += this.vy;

                // 粒子跑出屏幕边缘后，从对面重新出现，从而不会导致屏幕粒子数量变少
                if (this.x < 0) this.x = width;
                if (this.x > width) this.x = 0;
                if (this.y < 0) this.y = height;
                if (this.y > height) this.y = 0;

                // 鼠标交互
                let dx = mouse.x - this.x;
                let dy = mouse.y - this.y;
                let distance = Math.sqrt(dx * dx + dy * dy);

                // 鼠标的作用范围是150像素
                let maxDistance = 150;

                if (distance < maxDistance) {
                    // 计算推开的方向
                    let forceDirectionX = dx / distance;
                    let forceDirectionY = dy / distance;
                    // 距离越近，推力越强
                    let force = (maxDistance - distance) / maxDistance;

                    // 增加一个平滑系数（数字越大推得越远，数字小则显得柔和）
                    let pushX = forceDirectionX * force * 5;
                    let pushY = forceDirectionY * force * 5;

                    // 将推力施加在坐标上，形成遇到鼠标绕开的效果
                    this.x -= pushX;
                    this.y -= pushY;
                }
            }

            // 画出粒子
            draw() {
                ctx.fillStyle = 'rgba(148, 163, 184, 0.8)';
                ctx?.beginPath();
                ctx?.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx?.closePath();
                ctx?.fill();
            }
        }

        // 按设备能力控制粒子数量，低性能手机不再硬扛 350 个粒子。
        let particleArray: Particle[] = [];
        const particleCount = isMobile ? 90 : (lowCoreDevice ? 180 : 300);
        for (let i = 0; i < particleCount; i++) {
            particleArray.push(new Particle());
        }

        // 动画主循环
        let frameId = 0;
        let paused = false;
        function animate() {
            if (paused) return;
            ctx?.clearRect(0, 0, width, height);

            for (let i = 0; i < particleArray.length; i++) {
                particleArray[i].update();
                particleArray[i].draw();
            }

            frameId = requestAnimationFrame(animate);
        }

        document.addEventListener('visibilitychange', () => {
            paused = document.hidden;
            if (paused) {
                cancelAnimationFrame(frameId);
            } else {
                animate();
            }
        });

        // 启动程序
        animate();
    });
</script>

<style>
    /* ================================================================= */
    /* 专属电影级起步出场动画 */
    /* ================================================================= */
    @keyframes momentumReveal {
        0% {
            opacity: 0;
            transform: translateY(40px) skewY(3deg);
            filter: blur(10px);
        }
        100% {
            opacity: 1;
            transform: translateY(0) skewY(0deg);
            filter: blur(0);
        }
    }

    .animate-hero-title {
        /* forwards 确保动画结束后保持在 100% 的状态 */
        animation: momentumReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.2s; /* 给网页渲染留一点点呼吸空间 */
        will-change: transform, opacity, filter;
    }

    .animate-hero-subtitle {
        animation: momentumReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.5s; /* 比标题晚 0.3 秒，形成视觉下沉 */
        will-change: transform, opacity, filter;
    }

    .animate-hero-arrow {
        animation: momentumReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 1.2s; /* 最晚出现，提示用户看完了标题该往下滚了 */
        will-change: transform, opacity, filter;
    }
</style>
